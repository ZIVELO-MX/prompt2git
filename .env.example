# Supabase — obtener en: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Solo para operaciones de servidor que requieren privilegios elevados
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform AI — OpenRouter key para el plan free (todos los usuarios sin BYOK la usan)
# El modelo free de OpenRouter ya está configurado en ai-provider.ts: meta-llama/llama-3.1-8b-instruct:free
# Esta key NUNCA se expone al cliente
OPENROUTER_API_KEY=sk-or-v1-...

# Platform AI — OpenCode Zen key para modelos free adicionales
# Obtener en: https://opencode.ai/auth (requiere cuenta + método de pago, modelos free no consumen saldo)
# Endpoint: https://opencode.ai/zen/v1/chat/completions
ZEN_API_KEY=sk-...
